!config/nwg-displays/**
!config/nwg-look
!config/nwg-look/**
!config/qalculate
!config/qalculate/**
!config/shelly
!config/shelly/**
!config/swaync
!config/swaync/**
!config/wallust
!config/wallust/**
!config/waybar
!config/waybar/**

# etc/ - all tracked
!etc/sysctl/
!etc/sysctl/**
